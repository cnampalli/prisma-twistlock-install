# Operator-supplied artefacts — NEVER commit
files/*.tar.gz
files/*.tar.gz.sha256
files/*.crt
files/*.key
files/*.pem

# Secrets
*.vault
vault_pass*
*.env
local-secrets.yml

# Ansible transient
*.retry
.ansible/
.cache/

# Molecule transient
molecule/**/.molecule/
molecule/**/tmp/

# Python transient
**/__pycache__/
**/*.pyc

# Editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store
