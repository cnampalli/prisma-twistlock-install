---
profile: production

exclude_paths:
  - .cache/
  - .github/
  - molecule/*/tmp/
  - molecule/*/.molecule/

# Air-gap + FIPS context drives these choices:
skip_list:
  # Internal registry + custom version pinning break fqcn-repeat checks.
  - fqcn[action-core]
  # Runbook uses ansible.builtin.command for openssl/firewall-cmd where a
  # module is either unavailable (firewall-cmd --reload handler) or loses
  # fidelity. Keep the lint active by default but allow explicit overrides.
  - no-changed-when
  # Role-internal registers (e.g. `shipped_cfg`, `cert_info`) and the
  # `node_exporter_*` defaults pre-date the no-role-prefix rule. Renaming
  # them would touch every role and the group_vars/inventory that supplies
  # overrides, with no functional benefit — the vars never leak outside
  # their role. Re-evaluate if any variable becomes a public role input.
  - var-naming[no-role-prefix]

warn_list:
  - experimental
  - role-name

use_default_rules: true
