# Managed by rhel_baseline (rhel_baseline_password_auth_exception=true).
# Scoped exception to the global `PasswordAuthentication no`: admins reaching
# the host from any of the listed source networks (and optional group) may use
# password auth (e.g. MobaXterm with AD credentials, or an Ansible control
# node coming from the AAP EE subnet). RHEL 8 Includes sshd_config.d/*.conf at
# the top of sshd_config, so this Match wins for matching connections only —
# everyone else still gets the hardened PasswordAuthentication no.
#
# Match Address accepts a comma-separated CIDR list natively; list every
# legitimate source network in rhel_baseline_password_auth_cidrs.
Match Address {{ rhel_baseline_password_auth_cidrs | join(',') }}{% if rhel_baseline_password_auth_group %} Group {{ rhel_baseline_password_auth_group }}{% endif %}

    PasswordAuthentication yes
