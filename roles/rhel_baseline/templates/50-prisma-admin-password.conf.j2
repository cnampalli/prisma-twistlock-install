# Managed by rhel_baseline (rhel_baseline_password_auth_exception=true).
# Scoped exception to the global `PasswordAuthentication no`: admins reaching the
# host from the admin/jump network (and optional group) may use password auth
# (e.g. MobaXterm with AD credentials). RHEL 8 Includes sshd_config.d/*.conf at
# the top of sshd_config, so this Match wins for matching connections only —
# everyone else still gets the hardened PasswordAuthentication no.
Match Address {{ rhel_baseline_password_auth_cidr }}{% if rhel_baseline_password_auth_group %} Group {{ rhel_baseline_password_auth_group }}{% endif %}

    PasswordAuthentication yes
