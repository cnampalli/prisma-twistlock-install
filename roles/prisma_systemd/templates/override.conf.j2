# Managed by Ansible — prisma-twistlock-install / prisma_systemd
[Service]
Restart=on-failure
RestartSec={{ prisma_systemd_restart_sec }}s
StandardOutput=journal
StandardError=journal
CPUAccounting=yes
MemoryAccounting=yes
IOAccounting=yes
TasksMax={{ prisma_systemd_tasks_max }}
MemoryHigh={{ prisma_systemd_memory_high }}
MemoryMax={{ prisma_systemd_memory_max }}
MemorySwapMax={{ prisma_systemd_memory_swap_max }}
