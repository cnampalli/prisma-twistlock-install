#!/usr/bin/env bash
set -euo pipefail

: "${PRISMA_BACKUP_USER:?missing in env}"
: "${PRISMA_BACKUP_TOKEN:?missing in env}"
: "${INTERNAL_BACKUP_URL:?missing in env}"

# Reject malformed / attacker-controlled URLs before handing them to curl.
case "${INTERNAL_BACKUP_URL}" in
  https://*|http://*) ;;
  *) echo "INTERNAL_BACKUP_URL must be http(s)://; got '${INTERNAL_BACKUP_URL}'" >&2; exit 2 ;;
esac
INTERNAL_BACKUP_URL="${INTERNAL_BACKUP_URL%/}"

ts=$(date -u +%Y%m%dT%H%M%SZ)
out="{{ prisma_backup_dir }}/prisma-${ts}.tar.gz"

{% set curl_tls = '-k' if prisma_backup_insecure_tls else '--cacert ' ~ prisma_backup_ca_bundle %}
curl -s {{ curl_tls }} --fail \
  -u "${PRISMA_BACKUP_USER}:${PRISMA_BACKUP_TOKEN}" \
  -o "${out}" \
  "https://{{ prisma_console_fqdn | default('localhost') }}:{{ prisma_https_port }}/api/v1/backups"

curl -s {{ curl_tls }} --fail \
  -T "${out}" \
  "${INTERNAL_BACKUP_URL}/$(basename "${out}")"

find "{{ prisma_backup_dir }}" -type f -mtime +{{ prisma_backup_retention_days }} -delete
